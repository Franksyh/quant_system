PORT=3000

# Optional Telegram push alerts.
# 1. Create a bot with @BotFather.
# 2. Send a message to your bot.
# 3. Put the bot token and your chat id here.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Scanner behavior.
SCAN_INTERVAL_MINUTES=5
ALERT_SCORE=62
ALERT_LIMIT=5

# Default Taiwan stock universe. Use numeric codes, 2330.TW, 8069.TWO,
# or explicit channels like tse_2330.tw / otc_8069.tw.
WATCHLIST=2330,2317,2454,2308,2382,2412,2881,2882,2886,2891,3711,2603,2615,2618,3037,3017,2357,3231,3443,3661,4966,6446,6669,8069,6488,3293,5371,6147,6187
