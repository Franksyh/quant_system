# ===== 模擬交易：建議先用這組 =====
TRADING_MODE=paper
ENABLE_LIVE_TRADING=false
MARKET_DATA_SOURCE=simulated
DEFAULT_BALANCE=500000
DEFAULT_ORDER_QTY=100
TRADE_INTERVAL_SECONDS=60
TRADING_STATE_FILE=data/trading_state.json
ORDER_LOG_FILE=data/order_log.csv

